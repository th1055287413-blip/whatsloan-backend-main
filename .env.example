# ==================== 数据库配置 ====================
# 数据库类型: postgresql, mysql, sqlite
DB_TYPE=postgresql
# 数据库主机地址
DB_HOST=127.0.0.1
# 数据库端口
DB_PORT=5432
# 数据库用户名
DB_USER=whatsapp
# 数据库密码
DB_PASSWORD=change_password
# 数据库名称
DB_NAME=whatsapp
# SSL 模式: disable, require, verify-full
DB_SSLMODE=disable

# ==================== Redis 配置 ====================
# Redis 主机地址
REDIS_HOST=127.0.0.1
# Redis 端口
REDIS_PORT=6379
# Redis 密码
REDIS_PASSWORD=
# Redis 数据库编号
REDIS_DB=0

# ==================== 服务器配置 ====================
# 服务器端口
SERVER_PORT=8080
# Gin 运行模式: debug, release
GIN_MODE=debug
LOG_LEVEL=debug

# ==================== JWT 配置 ====================
# JWT 密钥 (生产环境请使用强随机密钥)
JWT_SECRET=whatsapp-golang-jwt-secret-key-2024

SERVICE_API_KEY=TEST
